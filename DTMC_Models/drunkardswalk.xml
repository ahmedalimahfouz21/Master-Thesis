<?xml version="1.0"?>
<model type="DTMC" name="DrunkardsWalk">

        <define-state name="0" number= "0" type="absorbing" state_desirability = "2"/>
        <define-state name="1" number= "1" type="transient" state_desirability = "1"/>
        <define-state name="2" number= "2" type="transient" state_desirability = "0"/>
        <define-state name="3" number= "3" type="transient" state_desirability = "1"/>
        <define-state name="4" number= "4" type="absorbing" state_desirability = "2"/>
        
        <define-edge from="0" to="0" value="1.0" />
        
        <define-edge from="1" to="0" value="0.5" />
        <define-edge from="1" to="2" value="0.5" />
        
        <define-edge from="2" to="1" value="0.5" />
        <define-edge from="2" to="3" value="0.5" />
        
        <define-edge from="3" to="2" value="0.5" />
        <define-edge from="3" to="4" value="0.5" />
        
        <define-edge from="4" to="4" value="1.0" />
        
</model>
