<?xml version="1.0"?>
<model type="DTMC" name="CleaningRobot">

        <define-state name="S0(start)"      number="0" type="transient" state_desirability = "1"/>
        <define-state name="S1(sense1)"     number="1" type="transient" state_desirability = "2"/>
        <define-state name="S2(sense2)"     number="2" type="transient" state_desirability = "2"/>
        <define-state name="S3(analyze)"    number="3" type="transient" state_desirability = "2"/>
        <define-state name="S4(go forward)" number="4" type="transient" state_desirability = "3"/>
        <define-state name="S5(rotate)"     number="5" type="transient" state_desirability = "3"/>
        <define-state name="S6(faliure)"    number="6" type="absorbing" state_desirability = "0"/>
        <define-state name="S7(faliure)"    number="7" type="absorbing" state_desirability = "0"/>
        <define-state name="S8(success)"    number="8" type="absorbing" state_desirability = "4"/>
        <define-state name="S9(sense3)"     number="9" type="transient" state_desirability = "2"/>

        <define-edge from="0" to="1" value="0.90" />
        <define-edge from="0" to="2" value="0.10" />

        
        <define-edge from="1" to="2" value="0.20" />
        <define-edge from="1" to="3" value="0.70" />
        <define-edge from="1" to="9" value="0.10" />
               
        <define-edge from="2" to="3" value="0.95" />
        <define-edge from="2" to="6" value="0.05" />
        
        <define-edge from="3" to="4" value="0.20" />
        <define-edge from="3" to="5" value="0.80" />
        
        <define-edge from="4" to="5" value="0.90" />
        <define-edge from="4" to="7" value="0.05" />
        <define-edge from="4" to="8" value="0.05" />
        
        <define-edge from="5" to="4" value="0.95" />
        <define-edge from="5" to="7" value="0.05" />

        <define-edge from="6" to="6" value="1.0" />
        
        <define-edge from="7" to="7" value="1.0" />
        
        <define-edge from="8" to="8" value="1.0" />
        
        <define-edge from="9" to="3" value="0.95" />
        <define-edge from="9" to="4" value="0.05" />
        
                   
</model>
